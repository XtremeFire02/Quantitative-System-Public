# ─────────────────────────────────────────────────────────────────────────────
# Paper Trading Backend — Environment Variables
#
# Copy this file to paper_trading/backend/.env and fill in values.
# The backend reads these at startup via os.getenv(). Never commit .env.
#
# Mandatory: none — the system runs with defaults for local development.
# Optional:  email alerts (all ALERT_* keys must be set together to enable).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Absolute path to the SQLite file. Default: paper_trading/backend/paper_trading.db
# PAPER_TRADING_DB=/data/paper_trading.db

# ── Email Alerts (all four required to enable) ────────────────────────────────
# Leave blank to disable email alerts (DB alerts still fire).
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=your-address@gmail.com
ALERT_SMTP_PASS=your-app-password
ALERT_EMAIL_TO=recipient@example.com

# ── External APIs ─────────────────────────────────────────────────────────────
# These default to the public endpoints below. Override for staging/testing.
# BINANCE_FAPI_BASE=https://fapi.binance.com
# DERIBIT_BASE=https://www.deribit.com/api/v2/public

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Hour (UTC) at which the daily signal job fires. Default: 0 (midnight UTC).
# DAILY_JOB_HOUR_UTC=0

# Exit check interval in minutes. Default: 15.
# EXIT_CHECK_INTERVAL_MINUTES=15

# ── Data staleness ────────────────────────────────────────────────────────────
# DVOL/price data older than this (minutes) blocks new trades. Default: 120.
# DATA_STALE_MINUTES=120
