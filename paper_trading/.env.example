# ── Environment ───────────────────────────────────────────────────────────────
ENV=development

# ── API authentication (generate: python -c "import secrets; print(secrets.token_hex(32))")
API_KEY=

# ── Database
DATABASE_URL=sqlite:////app/data/paper_trading.db
# PostgreSQL example (for production):
# DATABASE_URL=postgresql://pt_user:changeme@postgres:5432/paper_trading

# ── Binance API (for live order execution — leave empty for paper trading)
BINANCE_API_KEY=
BINANCE_API_SECRET=
LIVE_TRADING_ENABLED=false

# ── Telegram alerts (optional — set both to enable push notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email alerts (all 4 required to enable)
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASS=
ALERT_EMAIL_TO=

# ── CORS (comma-separated exact origins allowed in production)
# Example: CORS_ORIGINS=https://terminal.myhedgefund.com,https://demo.myhedgefund.com
CORS_ORIGINS=

# ── Scheduler
DAILY_JOB_HOUR_UTC=0
EXIT_CHECK_INTERVAL_MINUTES=15

# ── Data staleness threshold
DATA_STALE_MINUTES=120

# ── Log retention (system_logs table is pruned to this many days by the daily job)
LOG_RETENTION_DAYS=90

# ── Position sizing
POSITION_NOTIONAL_USD=10000.0
POSITION_SIZING_MODE=fixed
PORTFOLIO_VOL_TARGET=0.10
POSITION_CONCENTRATION_CAP=0.25
POSITION_MIN_USD=1000.0
POSITION_MAX_USD=100000.0

# ── Portfolio risk limits
PORTFOLIO_MAX_OPEN_POSITIONS=3
PORTFOLIO_MAX_SAME_MARKET=2
PORTFOLIO_MAX_DAILY_LOSS_BP=-500.0
PORTFOLIO_MAX_STRATEGY_DD_PCT=-0.20
PORTFOLIO_MAX_CONSECUTIVE_LOSSES=4
PORTFOLIO_MAX_GROSS_NOTIONAL_USD=50000.0
